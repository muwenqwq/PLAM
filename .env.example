# EduAgent Studio / LearnAgent-A3 environment template
# Copy to .env for local Docker Compose use. Do not commit real secrets.

COMPOSE_PROJECT_NAME=eduagent-studio

MYSQL_DATABASE=eduagent_studio
MYSQL_ROOT_PASSWORD=eduagent_root_password
MYSQL_USERNAME=root
MYSQL_PASSWORD=eduagent_root_password
MYSQL_PORT=3306

REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DATABASE=0

BACKEND_PORT=8080
JWT_SECRET=eduagent-studio-local-demo-secret-change-before-production
JWT_EXPIRATION_MINUTES=1440
JWT_ISSUER=eduagent-studio

AI_SERVICE_PORT=8000
AI_SERVICE_NAME=eduagent-ai-service
AI_SERVICE_VERSION=0.1.0
AI_SERVICE_MOCK_MODE=true
AI_SERVICE_BASE_URL=http://ai-service:8000

FRONTEND_PORT=5173
VITE_API_BASE_URL=/api

# Optional real model configuration. Keep empty for Mock mode.
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=
