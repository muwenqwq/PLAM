# ====================
# LearnAgent-A3 .gitignore
# ====================

# ====================
# 文档文件夹（不提交到仓库）
# ====================
temp/


# ====================
# 环境变量和密钥
# ====================
.env
.env.local
.env.*.local
*.env

# ====================
# IDE 和编辑器
# ====================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ====================
# Java / Spring Boot
# ====================
target/
*.class
*.jar
*.war
*.ear
*.log
.mvn/
mvnw
mvnw.cmd

# ====================
# Python
# ====================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
*.egg-info/
dist/
build/
.eggs/

# ====================
# Node.js / Vue
# ====================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dist/
.nuxt/
.output/

# ====================
# 数据库
# ====================
*.db
*.sqlite
*.sqlite3

# ====================
# Docker
# ====================
docker-compose.override.yml

# ====================
# 系统文件
# ====================
.DS_Store
Thumbs.db
desktop.ini

# ====================
# 临时文件
# ====================
*.tmp
*.temp
*.bak
*.backup
