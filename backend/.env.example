# ============================================
# LearnAgent-A3 后端环境变量配置模板
# 复制本文件为 .env 并填入真实值
# .env 已被 .gitignore 忽略，不会提交到 Git
# ============================================

# MySQL 数据库
DB_HOST=localhost
DB_PORT=3306
DB_NAME=learnagent_a3
DB_USERNAME=root
DB_PASSWORD=你的数据库密码

# Python AI 服务
AI_SERVICE_URL=http://localhost:8000

# JWT 密钥（至少 256 位，留空使用默认值）
JWT_SECRET=

# Spring 活跃配置
SPRING_PROFILES_ACTIVE=dev
